# Copy to .env and fill in. Only AGENT_KEY is required.

# From the Observer console: Agents → New agent → name it "demo-agent" →
# copy the obs_live_* key (shown exactly once).
AGENT_KEY=

# Observer Cloud endpoint. Leave as-is unless self-hosting.
CLOUD_SERVER_URL=https://use.observer

# Bearer token the otlp-pusher uses against the agent's OTLP receiver.
# Any shared secret works; it never leaves the compose network.
OTLP_TOKEN=demo-otlp-token

# ── Optional: CloudWatch ────────────────────────────────────────────────
# Uncomment here AND in docker-compose.yml AND in observer.yaml to read a
# real AWS metric. Read-only credentials are plenty (cloudwatch:GetMetricData).
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
